# LLM API 설정 (OpenAI 호환)
OPENAI_BASE_URL=https://gateway.letsur.ai/v1
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=claude-opus-4-5-20251101

# 데이터 저장 경로
DATA_PATH=/data

# Documents 경로 설정 (Docker 마운트와 호스트 경로를 동일하게)
LOCAL_BASE_PATH=/home/amos/Documents
REMOTE_BASE_PATH=~/Documents

# 로컬 머신 별칭 (서버가 돌아가는 머신, machine=nuc인 프로젝트를 로컬로 처리)
LOCAL_MACHINE=nuc

# 원격 호스트 설정 (별칭:주소 형태, 쉼표로 구분) - 선택사항
# 예: mac:amos@100.73.228.37,nuc2:user@192.168.1.50
# REMOTE_HOSTS=mac:user@your-mac-ip
