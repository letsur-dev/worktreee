# LLM API 설정 (OpenAI 호환)
OPENAI_BASE_URL=https://gateway.letsur.ai/v1
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=claude-opus-4-5-20251101

# 데이터 저장 경로
DATA_PATH=/data

# Documents 경로 설정 (Docker 마운트와 호스트 경로를 동일하게)
# LOCAL_BASE_PATH defaults to ~/Documents (override if needed)
# LOCAL_BASE_PATH=/home/youruser/Documents
REMOTE_BASE_PATH=~/Documents

# 로컬 머신 별칭 (서버가 돌아가는 머신, 이 값과 일치하는 machine을 로컬로 처리)
# LOCAL_MACHINE=local

# 로컬 머신 SSH 접속 주소 (Docker 안에서 tailscale 못 쓰므로 직접 지정)
# CLIENT_MACHINE에서 Gateway로 접속할 때 사용
# LOCAL_SSH_ADDR=user@tailscale-ip

# 클라이언트 머신 별칭 (브라우저가 돌아가는 머신, idea:// 스킴 사용)
# CLIENT_MACHINE=mac

# 원격 호스트 설정 (별칭:주소 형태, 쉼표로 구분) - 선택사항
# 예: mac:user@192.168.1.10,server2:user@192.168.1.50
# REMOTE_HOSTS=mac:user@your-mac-ip

# Claude CLI 인증은 ~/.claude 마운트로 자동 공유됨 (별도 설정 불필요)

# Jira API 설정 (선택사항)
# JIRA_URL=https://your-company.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your-jira-api-token
